# Copy to .env and fill in real values. Never commit .env.

# --- Database ---------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# --- Clerk auth -------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Google Gemini ----------------------------------------------------------
GEMINI_API_KEY=

# --- Transloadit (primary media CDN) ----------------------------------------
# Both values must be set for Transloadit to be used. If either is missing the
# app falls back to Cloudinary.
#   Auth key    : Account -> API Settings -> Auth Key
#   Template id : Templates -> New
# Minimal template that returns a CDN URL:
#   { "steps": { ":original": { "robot": "/upload/handle" } } }
TRANSLOADIT_AUTH_KEY=
TRANSLOADIT_TEMPLATE_ID=

# --- Cloudinary (fallback CDN + crop transformation) ------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Trigger.dev (optional) -------------------------------------------------
TRIGGER_SECRET_KEY=

# --- Misc -------------------------------------------------------------------
# Base URL used by the local-disk storage fallback (development only)
APP_URL=http://localhost:3000
